{
  "name": "prompt-lock",
  "version": "0.2.0",
  "description": "Version control and behavioral regression testing for LLM prompts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "prompt-lock": "dist/cli.js",
    "promptlock": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "demo": "npm run build && node demo.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shmulikdav/Promptlock.git"
  },
  "homepage": "https://github.com/shmulikdav/Promptlock#readme",
  "bugs": {
    "url": "https://github.com/shmulikdav/Promptlock/issues"
  },
  "author": "Shmuli David",
  "keywords": [
    "llm",
    "prompt",
    "testing",
    "regression",
    "ai",
    "openai",
    "anthropic",
    "evaluation",
    "snapshot",
    "ollama",
    "prompt-engineering"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "diff": "^5.2.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  }
}
